<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/light_bg"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #1024"
                android:textColor="@color/dark_bg"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true" />

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />

        </RelativeLayout>

        <!-- БЛОК ДАТЫ И ВРЕМЕНИ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: 17/06/2026"
                android:textColor="@color/text_grey"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvOrderTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Time: --:--"
                android:textColor="@color/text_grey"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- БЛОК АДРЕСА ДОСТАВКИ -->
        <TextView
            android:id="@+id/tvOrderAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Address: Loading..."
            android:textColor="@color/dark_bg"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- Карусель товаров внутри заказа -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrderItemsHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:overScrollMode="never" />

        <TextView
            android:id="@+id/tvOrderTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total: 12 500 ₽"
            android:textAlignment="viewEnd"
            android:textColor="@color/dark_bg"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>