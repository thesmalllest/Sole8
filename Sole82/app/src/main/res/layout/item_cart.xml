<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:gravity="top">   <!-- ВЫРАВНИВАЕМ ВСЕ ПО ВЕРХУ -->

    <!-- IMAGE -->
    <ImageView
        android:id="@+id/cartItemImage"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo" />

    <!-- TEXTS -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingLeft="12dp"
        android:gravity="top">   <!-- ВЫРАВНИВАЕМ ТЕКСТ ПО ВЕРХУ -->

        <TextView
            android:id="@+id/cartItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/dark_bg" />

        <TextView
            android:id="@+id/cartItemSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Size: 42"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/cartItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="38 200 ₽"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- QUANTITY CONTROLS -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="top">   <!-- ВЫРАВНИВАНИЕ ПО ВЕРХУ -->

        <ImageView
            android:id="@+id/cartMinus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_minus" />

        <TextView
            android:id="@+id/cartQty"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="18sp"
            android:text="1" />

        <ImageView
            android:id="@+id/cartPlus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_plus" />
    </LinearLayout>

    <!-- REMOVE BUTTON -->
    <ImageView
        android:id="@+id/cartRemove"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="6dp"
        android:layout_marginLeft="8dp"
        android:src="@drawable/ic_delete" />
</LinearLayout>
